# Redis (Upstash or any Redis-compatible provider)
# Standard redis:// connection string
REDIS_URL=

# Vercel AI Gateway (daily brief + future LLM features). On Vercel, OIDC via `vercel env pull` is preferred.
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Root domain — used by middleware for subdomain detection
# Set to localhost:3000 for local dev, your actual domain in production
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
