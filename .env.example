# Redis (Upstash or any Redis-compatible provider)
# Standard redis:// connection string
REDIS_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Root domain — used by middleware for subdomain detection
# Set to localhost:3000 for local dev, your actual domain in production
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Sentry error monitoring (optional — leave blank to disable)
# DSN from https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Auth token for source map uploads (CI only)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
